# Project N.O.M.A.D. — Synology configuration
# Copy this file to .env and fill in all values before running docker compose up.

# ─── Admin URL ────────────────────────────────────────────────────────────────
# Set this to your NAS IP address and the port you chose (default 8888)
URL=http://192.168.1.x:8888

# ─── Secrets ──────────────────────────────────────────────────────────────────
# Generate these with: openssl rand -hex 32
APP_KEY=
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=

# ─── Database ─────────────────────────────────────────────────────────────────
# Safe to leave as-is unless you have a reason to change
MYSQL_DATABASE=nomad
MYSQL_USER=nomad_user

# ─── Optional ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
